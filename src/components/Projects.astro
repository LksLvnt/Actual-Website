---
const projects = [
  { key: '1', tech: ['Angular', 'PrimeNG', 'Tailwind'], href: 'https://github.com/lokoslevente' },
  { key: '2', tech: ['Spring Boot', 'Thymeleaf', 'H2'], href: 'https://github.com/lokoslevente' },
  { key: '3', tech: ['React', 'FastAPI', 'pgvector'], href: 'https://studymate.lokoslevente.com' },
  { key: '4', tech: ['Astro', 'Tailwind', 'Three.js'], href: 'https://lokoslevente.com' },
];
---
<section class="py-28 md:py-40 px-5 md:px-20 max-w-[1440px] mx-auto bg-alt" id="work">
  <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-16 gap-4">
    <h2 class="font-serif text-[clamp(2rem,4vw,4rem)] font-bold text-[var(--text)] leading-[1.2] tracking-[-0.02em]">
      <span data-i18n="projects.title1">Selected</span> <span class="text-[var(--accent)] italic" data-i18n="projects.title2">Projects</span>
    </h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {projects.map((p) => (
      <a href={p.href} class="project-card group" target="_blank" rel="noopener">
        <div class="absolute inset-0 bg-gradient-to-br from-[var(--accent)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10 flex justify-between items-start">
          <div class="flex gap-2 flex-wrap">
            {p.tech.map((t) => <span class="chip">{t}</span>)}
          </div>
          <svg class="w-5 h-5 text-[var(--accent-dim)] group-hover:text-[var(--accent)] transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
        </div>
        <div class="relative z-10 mt-auto">
          <h3 class="font-serif text-xl md:text-[1.75rem] font-semibold text-[var(--text)] mb-3 group-hover:text-[var(--accent)] transition-colors leading-[1.3]" data-i18n={`projects.${p.key}.title`}></h3>
          <p class="font-sans text-sm md:text-base text-[var(--text-muted)] leading-relaxed" data-i18n={`projects.${p.key}.desc`}></p>
        </div>
      </a>
    ))}
  </div>
</section>