---
const categories = [
  { key: 'cat1', items: ['C#', 'C', 'C++', 'Java', 'Python', 'JavaScript', 'TypeScript', 'SQL', 'Assembly', 'HTML/CSS'] },
  { key: 'cat2', items: ['Angular', 'Astro', 'React', 'Spring Boot', '.NET', 'FastAPI', 'Tailwind CSS', 'Node.js'] },
  { key: 'cat3', items: ['Git', 'Docker', 'Linux', 'PostgreSQL', 'Supabase', 'Vercel', 'Three.js'] },
];
---
<section class="py-28 md:py-40 px-5 md:px-20 max-w-[1440px] mx-auto" id="tech">
  <p class="font-sans text-xs font-semibold tracking-[0.2em] uppercase text-[var(--accent)]/60 mb-4" data-i18n="tech.label">Toolbox</p>
  <h2 class="font-serif text-[clamp(2rem,4vw,4rem)] font-bold text-[var(--text)] mb-12 md:mb-16 leading-[1.2] tracking-[-0.02em]">
    <span data-i18n="tech.title1">Tech</span> <span class="text-[var(--accent)] italic" data-i18n="tech.title2">Stack</span>
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
    {categories.map((cat) => (
      <div>
        <h3 class="font-sans text-xs font-semibold tracking-[0.2em] uppercase text-[var(--highlight)] mb-6" data-i18n={`tech.${cat.key}`}></h3>
        <div class="flex flex-wrap gap-3">
          {cat.items.map((item) => <span class="tech-chip">{item}</span>)}
        </div>
      </div>
    ))}
  </div>
</section>