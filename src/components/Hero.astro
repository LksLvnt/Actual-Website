---
---
<section class="relative min-h-screen w-full flex items-center overflow-hidden pt-20">
  <div class="max-w-[1440px] mx-auto px-5 md:px-20 w-full grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
    <div class="md:col-span-5 flex flex-col justify-center py-16 md:py-24">
      <h1 class="font-serif text-[clamp(3rem,8vw,7rem)] font-black text-[var(--text)] uppercase leading-[1.05] tracking-[-0.04em] mb-2" data-i18n="hero.line1">Creative</h1>
      <h1 class="font-serif text-[clamp(3rem,8vw,7rem)] font-black text-[var(--accent)] uppercase leading-[1.05] tracking-[-0.04em] italic mb-8" data-i18n="hero.line2">Vision</h1>
      <p class="font-sans text-base md:text-lg text-[var(--text-muted)] max-w-md leading-relaxed mb-10" data-i18n="hero.subtitle">Engineer by day, creative by nature. Building the future with precision and passion.</p>
      <div>
        <a class="group inline-flex items-center gap-2 px-7 py-3.5 bg-[var(--accent)] text-[var(--bg)] font-sans text-xs font-semibold tracking-[0.1em] uppercase rounded-[4px] bloom-shadow transition-all duration-300 hover:bg-[var(--accent-light)]" href="#work">
          <span data-i18n="hero.cta">View Selected Work</span>
          <svg class="w-4 h-4 group-hover:translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        </a>
      </div>
    </div>
    <div class="md:col-span-7 flex justify-end">
      <div class="w-full max-w-lg md:max-w-none rounded-xl overflow-hidden border border-white/[0.06]">
        <img src="/hero.png" alt="Levente Lokos" class="w-full h-auto object-cover" />
      </div>
    </div>
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[var(--bg)] to-transparent"></div>
</section>