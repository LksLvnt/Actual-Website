---
---
<section class="py-28 md:py-40 px-5 md:px-20 max-w-[1440px] mx-auto" id="contact">
  <div class="max-w-2xl mx-auto text-center">
    <p class="font-sans text-xs font-semibold tracking-[0.2em] uppercase text-[var(--highlight)] mb-4" data-i18n="contact.label">Get in Touch</p>
    <h2 class="font-serif text-[clamp(2rem,4vw,4rem)] font-bold text-[var(--text)] mb-6 leading-[1.2] tracking-[-0.02em]">
      <span data-i18n="contact.title1">Let's</span> <span class="text-[var(--accent)] italic" data-i18n="contact.title2">Connect</span>
    </h2>
    <p class="font-sans text-base md:text-lg text-[var(--text-muted)] mb-12 leading-relaxed" data-i18n="contact.subtitle">Have a project idea, a question, or just want to say hi? I'd love to hear from you.</p>
    <form class="space-y-8 text-left" id="contact-form">
      <div><input type="text" class="contact-input" data-i18n-placeholder="contact.name" placeholder="Your Name" required /></div>
      <div><input type="email" class="contact-input" data-i18n-placeholder="contact.email" placeholder="Your Email" required /></div>
      <div><textarea rows="4" class="contact-input resize-none" data-i18n-placeholder="contact.message" placeholder="Your Message" required></textarea></div>
      <div class="text-center">
        <button type="submit" class="px-10 py-4 bg-[var(--accent)] text-[var(--bg)] font-sans text-xs font-semibold tracking-[0.1em] uppercase rounded-[4px] bloom-shadow transition-all duration-300 hover:bg-[var(--accent-light)]" data-i18n="contact.send">Send Message</button>
      </div>
    </form>
  </div>
</section>